# ── Server ──────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── PostgreSQL ───────────────────────────────────
POSTGRES_URL=postgresql://user:password@localhost:5432/collab_editor

# ── MongoDB ──────────────────────────────────────
MONGO_URL=mongodb://localhost:27017/collab_ops

# ── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_in_production
JWT_REFRESH_SECRET=another_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AWS S3 (optional: snapshots) ─────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=collab-editor-snapshots
S3_REGION=ap-south-1
